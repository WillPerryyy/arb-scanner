# Scanning configuration
SCAN_INTERVAL_SECONDS=45
CACHE_TTL_SECONDS=30
MIN_NET_PROFIT_DOLLARS=0.001
FUZZY_MATCH_THRESHOLD=0.72

# API Keys (leave blank to skip that scanner's key-gated features)
# The Odds API: https://the-odds-api.com  (free tier = 500 requests/month)
ODDS_API_KEY=

# Kalshi API key (optional — public endpoints work without it)
KALSHI_API_KEY=

# Polymarket API key (optional)
POLYMARKET_API_KEY=
